# Local scripts use the service account JSON at the repo root.
# Do not use FIREBASE_* keys here — Firebase reserves that prefix for deploy.

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Resend Configuration (for Emails)
RESEND_API_KEY=your_resend_api_key

# App Configuration
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# SuperAdmin seed (used by seedAdmin Cloud Function and npm run seed:superadmin)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User
SEED_ADMIN_PHONE=
SEED_ADMIN_SECRET=change-me-to-a-long-random-secret
