# ============================================================================
# BACKEND - Cloud Functions Environment Template
# ============================================================================
# Copy this file to .env and fill in your values
# These are SECRETS - DO NOT commit actual values to git!
# Set these in Vercel environment variables for production

# ============================================================================
# FIREBASE CONFIGURATION
# ============================================================================
# Service account credentials are loaded via GOOGLE_APPLICATION_CREDENTIALS
# Set this in Cloud Functions environment variable to point to service account JSON
# Format: firebase-service-account.json (in project root)

# ============================================================================
# PAYMENT GATEWAY - Razorpay (SECRETS - DO NOT COMMIT)
# ============================================================================
# Get from Razorpay Dashboard > API Keys
RAZORPAY_KEY_ID=your_razorpay_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ============================================================================
# EMAIL SERVICE - Resend (SECRETS - DO NOT COMMIT)
# ============================================================================
# Get from Resend Dashboard > API Keys
# Get from your service configuration in the database
RESEND_API_KEY=your_resend_api_key
FROM_EMAIL_NAME=ServiceVerse Support
FROM_EMAIL_ADDRESS=noreply@serviceverse.com

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
NODE_ENV=production
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# ============================================================================
# SUPERADMIN SEED (Local Development Only)
# ============================================================================
# Used by scripts/seed-admin.js to create initial SuperAdmin user
# Only needed for local development - do not set in production
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=generate-a-strong-password
SEED_ADMIN_FIRST_NAME=Admin
SEED_ADMIN_LAST_NAME=User
SEED_ADMIN_PHONE=9000000000
SEED_ADMIN_SECRET=generate-a-long-random-secret-key
