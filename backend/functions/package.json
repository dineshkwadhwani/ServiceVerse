{
  "name": "serviceverse-functions",
  "version": "1.0.0",
  "description": "ServiceVerse Cloud Functions",
  "type": "commonjs",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc && tsc-alias",
    "seed:superadmin": "node scripts/seedSuperAdmin.js",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.0",
    "dotenv": "^16.3.0",
    "express": "^4.18.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.7.0",
    "razorpay": "^2.9.0",
    "resend": "^3.0.0",
    "sharp": "^0.33.0",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "firebase-functions-test": "^3.1.0",
    "tsc-alias": "^1.9.0",
    "typescript": "^5.3.0"
  }
}
