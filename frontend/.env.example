# ============================================================================
# FRONTEND - Environment Configuration Template
# ============================================================================
# Copy this file to .env.local and fill in your values
# All variables are PUBLIC (safe to commit) - DO NOT add secrets here!
# Prefix all variables with VITE_ for Vite to expose them to the frontend

# ============================================================================
# FIREBASE CONFIGURATION (Public - Safe to commit)
# ============================================================================
# Get these values from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ============================================================================
# PAYMENT GATEWAY - Razorpay (Public Test Key Only)
# ============================================================================
# Get from Razorpay Dashboard > API Keys
VITE_RAZORPAY_KEY_ID=your_razorpay_key

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================
VITE_APP_NAME=ServiceVerse
VITE_APP_URL=http://localhost:5173

# ============================================================================
# API CONFIGURATION
# ============================================================================
# Backend API URL - Points to Cloud Functions
# Format: https://us-central1-YOUR_PROJECT_ID.cloudfunctions.net/api
VITE_API_URL=https://us-central1-your_project_id.cloudfunctions.net/api
